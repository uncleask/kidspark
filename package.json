{
  "name": "kidspark",
  "version": "1.0.0",
  "description": "AI 驱动的家庭童创素材库",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --project tsconfig.electron.json",
    "preview": "vite preview",
    "electron": "npm run build && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.kids.creative.library",
    "productName": "KidSpark",
    "copyright": "Copyright © 2026 KidSpark",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "directories": {
      "output": "dist-electron"
    },
    "extraMetadata": {
      "main": "dist-electron/electron/main.js"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "antd": "^5.21.6",
    "better-sqlite3": "^12.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "^5.2.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.0",
    "wait-on": "^8.0.1"
  }
}