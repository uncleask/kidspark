{
  "name": "KidSpark",
  "version": "1.0.0",
  "description": "AI 驱动的家庭素材库",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --project tsconfig.electron.json",
    "preview": "vite preview",
    "electron": "npm run build && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-rebuild"
  },
  "build": {
    "appId": "com.kidspark.app",
    "productName": "KidSpark",
    "copyright": "Copyright © 2026 KidSpark",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*.js",
      "!electron/**/*.ts",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "executableName": "kidspark",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "kidspark-${version}-portable.exe"
    },
    "asar": true,
    "npmRebuild": true,
    "nodeGypRebuild": false,
    "electronDist": "node_modules/electron/dist"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "antd": "^5.21.6",
    "better-sqlite3": "^12.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "^5.2.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.0",
    "wait-on": "^8.0.1"
  }
}